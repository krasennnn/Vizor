{
  "extends": "@istanbuljs/nyc-config-typescript",
  "all": true,
  "check-coverage": false,
  "reporter": ["lcov", "text", "html"],
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "cypress/**",
    "**/*.d.ts",
    "src/main.tsx",
    "src/vite-env.d.ts"
  ],
  "temp-dir": ".nyc_output"
}

